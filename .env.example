# BIST Pro — ornek ortam degiskenleri. Gercek .env GIT'E GIRMEZ (.gitignore).
# Kopyala: cp .env.example .env  ve degerleri doldur.

# --- Mevcut (Telegram / TradingView) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_NEWS_BOT_TOKEN=             # opsiyonel: haber bildirimlerini AYRI bota ayirir (bos = ana bot)
TELEGRAM_NEWS_CHAT_ID=
TV_USERNAME=
TV_PASSWORD=
TV_SESSION=                          # opsiyonel: user/pass yerine dogrudan oturum cerezi
TV_SESSION_SIGN=
USE_TV_LIVE=1                        # 0 = TradingView canli WS kapali, yalniz yfinance fallback

# --- Calistirma / veritabani ---
PORT=5000
SOLO_MODE=1                          # 1 = ev kullanimi: auth bypass, userId otomatik (bkz. SOLO_USER_ID)
SOLO_USER_ID=0fec3983
SOLO_USERNAME=Kaan
DB_PATH=                             # bos = <proje>/bist.db
DATABASE_URL=                        # bos = SQLite kullan
SECRET_KEY=                          # bos = BASE_DIR'den turetilir (tek-kullanici icin yeterli)
VERBOSE_FETCH=0                      # 1 = her veri cekiminin detayini logla (gurultulu)

# --- OpenAI AI ikincil filtre + read-only asistan ---
OPENAI_API_KEY=sk-...                 # SADECE backend'de; frontend'e asla gitmez
OPENAI_MODEL=gpt-5.4-mini             # OpenAI'daki guncel model adiyla dogrula
AI_REVIEW_ENABLED=1                   # 0 = AI tamamen kapali, eski akis
AI_REVIEW_FAIL_MODE=manual_review     # AI hata/limit → manuel incele (otomatik ACMAZ)
AI_REVIEW_TIMEOUT_SEC=15
AI_REVIEW_TOP_N=5                     # her taramada en fazla kac adaya AI (maliyet)
AI_MIN_SCORE_FOR_REVIEW=7             # bu skorun altindaki adaya AI calismaz
AI_MAX_OUTPUT_TOKENS=700
AI_MAX_TOOL_ROUNDS=4                  # asistan function-calling max tur (araç çağır→cevap); min 2
AI_DAILY_CALL_LIMIT=50                # gunluk max AI cagrisi
AI_MONTHLY_USD_LIMIT=10               # aylik tahmini USD tavani
AI_COOLDOWN_SAME_SYMBOL_MIN=60        # ayni sembol icin tekrar cagri araligi
AI_CACHE_TTL_MIN=60                   # taze inceleme cache suresi
AI_PRICE_INPUT_PER_1M=0.75           # maliyet tahmini icin 1M token USD (gpt-5.4-mini)
AI_PRICE_CACHED_INPUT_PER_1M=0.075   # cached input (indirimli) — prompt_tokens_details.cached_tokens
AI_PRICE_OUTPUT_PER_1M=4.50

# --- Sermaye guvenligi ---
AUTO_STRICT_CAPITAL=1                 # 1 = tam pozisyon sigmiyorsa clip degil ENGELLE

# --- Pozisyon buyuklugu (sizing) ---
# Nihai adet = min(risk-bazli adet, sermaye-tavani adedi). Tavan asagidaki yuzde.
AUTO_MAX_POSITION_PCT=20             # Hisse basi sermaye tavani (%). 12.000 TL * %20 = 2.400 TL/hisse
                                     # → sepet ~5 meyveye bolunur. Dusurursen daha cok hisse, kucuk paylar
AUTO_AI_SIZE_TILT=1                  # 1 = AI guveni dusukse payi KUCULT (yalniz kucultur, buyutmez;
                                     # faktor = clamp(conf/100, 0.6..1.0)). 0 = AI payi etkilemez

# --- Skor kalibrasyonu / asiri-alim cezasi (signal_calibration.py) ---
AUTO_OVERBOUGHT_PENALTY=1            # 1 = trend DISI rejimde yuksek RSI'yi skordan dus (RSI>=72 -2.5,
                                     # >=65 -1.5, >=58 -0.7). strong_bull/bull'da ceza YOK. 0 = kapali
                                     # Gerekce: ana kayip modu "zaten tepede olani al" idi
# 'Hizli-trade kurulum kalitesi' agirliklari (0-100 skoru; DENEYSEL, yon-ongorusu DEGIL).
# Kullanicinin GERCEK kazanan islemleriyle korele faktorlerden turetildi (Midas 3 ay, 39 islem).
SETUP_W_VOL=0.40                     # volatilite (hareket alani) agirligi
SETUP_W_RET=0.35                     # onceki 5g getiri (kisa momentum) agirligi
SETUP_W_RSI=0.25                     # RSI agirligi

# --- Cikis danismani (exit_advisor.py) — FAZ 3 ---
# Esikler TAHMIN DEGIL: 4.728 AL sinyalinin 1/3/5/10/20g tam yolundan cikarildi.
# Kaybeden kurali rejim testini gecti (yukselis aylarinda fark -4.33%, dusus -4.29%).
EXIT_ADVISOR_ENABLED=1               # 0 = cikis onerilerini tamamen kapat
EXIT_CUT_DEEP_PCT=-5                 # bu zarardan kotuyse (ve DEEP_DAYS gun gectiyse) guclu kes uyarisi
                                     # olcum: 3g<=-5% olanlarin yalniz %11.7'si 20g'de artida
EXIT_CUT_DEEP_DAYS=1                 # ⚠ 1.0 ALTINA CEKME: 1 gunden kisa ufuk icin OLCUMUMUZ YOK.
                                     # Gun-ici cokus zaten MARKET_VELOCITY_* hiz alarminda.
EXIT_CUT_MID_PCT=-3                  # olcum: 3g<=-3% olanlarin %16.4'u 20g'de artida (n=1238)
EXIT_CUT_MID_DAYS=3
EXIT_TAKE_PCT=5                      # olcum: 3g'de +5..10% olanlar 20g'ye kadar ort. %3.5 GERI VERDI
EXIT_TAKE_DAYS=3                     # ⚠ bu kural yon olarak tutarli ama buyuklugu rejime bagli

# --- PARK EDILMIS: kalite-bazli pay dagitimi (auto_trader_sizing.py) ---
# ALLOC_QUALITY_ENABLED=0 iken asagidaki ALLOC_* knoblarinin HICBIRI okunmaz.
# Neden park: sinyalin skor/guveni forward getiriyi ongormuyor (PF 0.75, 8+ bandi EN KOTU) —
# yani "kaliteye gore buyuk pay" stratejisi olculmus bir edge'e dayanmiyor, zarari buyutur.
# Silinmedi cunku setup_quality 1-ay OOS dogrulamasini gecerse yeniden acilabilir (2026-08-11).
ALLOC_QUALITY_ENABLED=0              # 1 = kalite-bazli standalone pay; 0 = duz tavan (AUTO_MAX_POSITION_PCT)
ALLOC_CONVICTION_MODE=confidence     # 'confidence' | 'score' | 'max' — pay dagitiminda lider metrik
ALLOC_FLOOR_PCT=10                   # kalite modunda hisse basi min pay (%)
ALLOC_CEIL_PCT=25                    # kalite modunda hisse basi max pay (%)
ALLOC_SCORE_MIN=5                    # skoru 0-1'e normalize ederken alt/ust sinir
ALLOC_SCORE_MAX=10
ALLOC_RR_MIN=1.0                     # R/R'yi 0-1'e normalize ederken alt/ust sinir
ALLOC_RR_MAX=3.0
ALLOC_RR_TILT=0.15                   # R/R'nin agirligi (tiebreaker; conviction lider kalir)
ALLOC_RR_FLOOR=1.3                   # bu R/R altindaki adaya ceza uygula
ALLOC_RR_PENALTY=0.6                 # ceza carpani (pay * 0.6)

# --- Veri tazeligi (data freshness gate) ---
AUTO_MAX_DATA_AGE_MIN=15             # Fiyat/hacim verisi bu dk'dan eskiyse sinyal URETME (feed kesintisi korumasi). 0 = kapali
AUTO_DELAYED_FEED_LAG_SEC=900        # Gecikmeli feed (yf fallback) icin varsayilan piyasa gecikmesi (sn). WS canli=0. Etkin yasa eklenir; ~900=15dk yf'i freshness gate'inde eler. 0 = kaynak-ayrimi kapali

# --- Piyasa-geneli erken uyari (market_alerts: hiz alarmi + endeks nabiz + bayat-fiyat) ---
MARKET_ALERTS_ENABLED=1              # 0 = tum piyasa uyari katmanini kapat
# Hiz alarmi: YALNIZ acik pozisyonlarda (portfoyde olmayan hisse icin bildirim GITMEZ)
MARKET_VELOCITY_WINDOW_MIN=15        # Hiz alarmi penceresi (dk): son bu surede dusus olcuur
MARKET_VELOCITY_DROP_PCT=4.0         # Pencerede >=%bu sert dususte uyar (portfoy hissesi)
MARKET_VELOCITY_COOLDOWN_MIN=30      # Ayni hisse icin tekrar uyari araligi (dk)
MARKET_VELOCITY_MIN_COVER_MIN=5      # Min gecmis (dk) — restart sonrasi false-fire onler
# Endeks iki-yonlu nabiz: XU100/XU030 gun ici degisim her adimda (dusus VE cikis) bildirilir
INDEX_STEP_PCT=0.5                   # Endeks bildirim adimi (puan). 0.5 = her %0.5 harekette bildir
INDEX_MOVE_COOLDOWN_SEC=90           # Sinir-titremesi korumasi: ayni endeks tekrar-bildirim min araligi (sn)
INDEX_CIRCUIT_L1_PCT=2.0             # Dususte -%bu gecince ayrica seviye-1 siddet isareti (kirmizi)
INDEX_CIRCUIT_L2_PCT=3.0             # Dususte -%bu = seviye-2 (cift kirmizi) + volatil mod
MARKET_VOLATILE_HOLD_MIN=5           # Uyari sonrasi bu kadar dk polling 30sn->10sn hizlanir (P2)
PORTFOLIO_STEP_ALERTS_ENABLED=1      # Acik pozisyonda gunluk degisim her N puan DUSUNCE bilgi ver (ince taneli, portfoy-ozel)
PORTFOLIO_STEP_PCT=1.0               # Adim buyuklugu (puan): +%8 -> +%7 gibi her %1 dususte uyar. Buyutursen daha az mesaj
PORTFOLIO_STEP_COOLDOWN_SEC=20       # Ayni pozisyon icin tekrar-uyari min araligi (sn) — cakismayi onler
MONITOR_MAX_PRICE_AGE_SEC=180        # Pozisyon monitoru: canli fiyat bu sn'den eskiyse SL'i kiyaslama, 'korumasiz' uyar (P1)
MONITOR_STALE_WARN_COOLDOWN_MIN=30   # Bayat-fiyat uyarisi tekrar araligi (dk)
