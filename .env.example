# BIST Pro — ornek ortam degiskenleri. Gercek .env GIT'E GIRMEZ (.gitignore).
# Kopyala: cp .env.example .env  ve degerleri doldur.

# --- Mevcut (Telegram / TradingView) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TV_USERNAME=
TV_PASSWORD=

# --- OpenAI AI ikincil filtre + read-only asistan ---
OPENAI_API_KEY=sk-...                 # SADECE backend'de; frontend'e asla gitmez
OPENAI_MODEL=gpt-5.4-mini             # OpenAI'daki guncel model adiyla dogrula
AI_REVIEW_ENABLED=1                   # 0 = AI tamamen kapali, eski akis
AI_REVIEW_FAIL_MODE=manual_review     # AI hata/limit → manuel incele (otomatik ACMAZ)
AI_REVIEW_TIMEOUT_SEC=15
AI_REVIEW_TOP_N=5                     # her taramada en fazla kac adaya AI (maliyet)
AI_MIN_SCORE_FOR_REVIEW=7             # bu skorun altindaki adaya AI calismaz
AI_MAX_OUTPUT_TOKENS=700
AI_MAX_TOOL_ROUNDS=4                  # asistan function-calling max tur (araç çağır→cevap); min 2
AI_DAILY_CALL_LIMIT=50                # gunluk max AI cagrisi
AI_MONTHLY_USD_LIMIT=10               # aylik tahmini USD tavani
AI_COOLDOWN_SAME_SYMBOL_MIN=60        # ayni sembol icin tekrar cagri araligi
AI_CACHE_TTL_MIN=60                   # taze inceleme cache suresi
AI_PRICE_INPUT_PER_1M=0.75           # maliyet tahmini icin 1M token USD (gpt-5.4-mini)
AI_PRICE_CACHED_INPUT_PER_1M=0.075   # cached input (indirimli) — prompt_tokens_details.cached_tokens
AI_PRICE_OUTPUT_PER_1M=4.50

# --- Sermaye guvenligi ---
AUTO_STRICT_CAPITAL=1                 # 1 = tam pozisyon sigmiyorsa clip degil ENGELLE

# --- Veri tazeligi (data freshness gate) ---
AUTO_MAX_DATA_AGE_MIN=15             # Fiyat/hacim verisi bu dk'dan eskiyse sinyal URETME (feed kesintisi korumasi). 0 = kapali
AUTO_DELAYED_FEED_LAG_SEC=900        # Gecikmeli feed (yf fallback) icin varsayilan piyasa gecikmesi (sn). WS canli=0. Etkin yasa eklenir; ~900=15dk yf'i freshness gate'inde eler. 0 = kaynak-ayrimi kapali

# --- Piyasa-geneli erken uyari (market_alerts: hiz alarmi + endeks devre kesici + bayat-fiyat) ---
MARKET_ALERTS_ENABLED=1              # 0 = tum piyasa uyari katmanini kapat
MARKET_VELOCITY_WINDOW_MIN=15        # Hiz alarmi penceresi (dk): son bu surede dusus olcuur
MARKET_VELOCITY_DROP_PCT=4.0         # Pencerede >=%bu dususte Telegram uyar (BIST100 u BIST30 evreni)
MARKET_VELOCITY_COOLDOWN_MIN=30      # Ayni hisse icin tekrar uyari araligi (dk)
MARKET_VELOCITY_MIN_COVER_MIN=5      # Min gecmis (dk) — restart sonrasi false-fire onler
INDEX_CIRCUIT_L1_PCT=2.0             # XU100/XU030 gun ici -%bu = seviye 1 devre kesici uyari
INDEX_CIRCUIT_L2_PCT=3.0             # -%bu = seviye 2 (daha siddetli)
INDEX_CIRCUIT_COOLDOWN_MIN=60        # Endeks uyarisi tekrar araligi (dk)
MARKET_VOLATILE_HOLD_MIN=5           # Uyari sonrasi bu kadar dk polling 30sn->10sn hizlanir (P2)
PORTFOLIO_STEP_ALERTS_ENABLED=1      # Acik pozisyonda gunluk degisim her N puan DUSUNCE bilgi ver (ince taneli, portfoy-ozel)
PORTFOLIO_STEP_PCT=1.0               # Adim buyuklugu (puan): +%8 -> +%7 gibi her %1 dususte uyar. Buyutursen daha az mesaj
PORTFOLIO_STEP_COOLDOWN_SEC=20       # Ayni pozisyon icin tekrar-uyari min araligi (sn) — cakismayi onler
MONITOR_MAX_PRICE_AGE_SEC=180        # Pozisyon monitoru: canli fiyat bu sn'den eskiyse SL'i kiyaslama, 'korumasiz' uyar (P1)
MONITOR_STALE_WARN_COOLDOWN_MIN=30   # Bayat-fiyat uyarisi tekrar araligi (dk)
